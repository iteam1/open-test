# Copy to .env (gitignored) and fill in what you need. Every value is
# optional — leave a line out entirely to use the default. Bun auto-loads
# .env into process.env with zero config; the app passes these explicitly
# to each session's query() subprocess via options.env.

# Point the Claude API at a different endpoint (e.g. a proxy or gateway).
ANTHROPIC_BASE_URL=

# Model for sessions' turns (e.g. claude-sonnet-5). Unset = the CLI default.
ANTHROPIC_MODEL=

# API key for the sessions' subprocesses. Unset = whatever auth the local
# Claude Code installation already has (e.g. claude.ai login).
ANTHROPIC_API_KEY=
